      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"violation_detected\": {\n      \"type\": \"boolean\",\n      \"description\": \"Whether a violation was detected in the image\"\n    },\n    \"event_type\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"PPE_VIOLATION\",\n        \"SAFETY_VIOLATION\",\n        \"RESTRICTED_AREA\",\n        \"ABNORMAL_ACTIVITY\",\n        \"NO_VIOLATION\"\n      ],\n      \"description\": \"Main event category detected in the image\"\n    },\n    \"severity\": {\n      \"type\": \"string\",\n      \"enum\": [\"CRITICAL\", \"HIGH\", \"MEDIUM\", \"LOW\", \"NONE\"],\n      \"description\": \"Severity level of the detected event\"\n    },\n    \"specific_violations\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"NO_HAIRNET\",\n          \"NO_MASK\",\n          \"NO_GLOVES\",\n          \"NO_APRON\",\n          \"NO_UNIFORM\",\n          \"NO_SAFETY_SHOES\",\n          \"NO_HELMET\",\n          \"NO_REFLECTIVE_JACKET\",\n\n          \"SPITTING\",\n          \"SMOKING\",\n          \"EATING_IN_RESTRICTED_AREA\",\n          \"DRINKING_IN_RESTRICTED_AREA\",\n          \"MOBILE_PHONE_USAGE\",\n          \"UNAUTHORIZED_ENTRY\",\n\n          \"FIRE_DETECTED\",\n          \"WATER_SPILL\",\n          \"SPARK_DETECTED\",\n          \"SLIP_HAZARD\",\n          \"BLOCKED_PATH\",\n          \"BLOCKED_EXIT\",\n          \"UNSAFE_MATERIAL_HANDLING\",\n\n          \"PERSON_DOWN\",\n          \"CROWDING\",\n          \"IDLE_ACTIVITY\",\n          \"ABNORMAL_MOVEMENT\"\n        ]\n      },\n      \"description\": \"List of specific violations detected in the image\"\n    },\n    \"description\": {\n      \"type\": \"string\",\n      \"description\": \"Brief human-readable description of what was detected\"\n    },\n    \"section\": {\n      \"type\": \"string\",\n      \"enum\": [\"production\", \"packing\", \"warehouse\", \"dispatch\", \"unknown\"],\n      \"description\": \"Facility section where the event occurred\"\n    }\n  },\n  \"required\": [\n    \"violation_detected\",\n    \"event_type\",\n    \"severity\",\n    \"specific_violations\",\n    \"description\",\n    \"section\"\n  ]\n}"
      },
